# Copy to `.env` next to docker-compose.yml and fill in the values before
# running `docker compose up`. Never commit the real `.env` — it contains
# the coordinator enrollment secret.

# ── required ────────────────────────────────────────────────────────────
BITNET_COORDINATOR_URL=https://bitnet-coord.ngrok.app/
BITNET_ENROLLMENT_KEY=change-me-to-a-long-random-string

# ── optional ────────────────────────────────────────────────────────────
# BITNET_WORKER_NAME=worker-a
# BITNET_CPU_THREADS=8
# BITNET_HEARTBEAT_SECONDS=30
# BITNET_SHUTDOWN_SECONDS=30
# BITNET_LOG_LEVEL=info
