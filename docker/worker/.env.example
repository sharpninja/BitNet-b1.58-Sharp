# ──────────────────────────────────────────────────────────────────────
# PREFERRED: for a single worker on one host, run the generic installer
# script from the repo's scripts/ directory:
#
#     # bash / Linux / macOS
#     curl -fsSL -o install-bitnet-worker.sh \
#         https://raw.githubusercontent.com/sharpninja/BitNet-b1.58-Sharp/main/scripts/install-bitnet-worker.sh
#     chmod +x install-bitnet-worker.sh
#     export BITNET_COORDINATOR_URL='https://<coordinator>:5001/'
#     export BITNET_WORKER_API_KEY='<operator-set-key>'
#     ./install-bitnet-worker.sh
#
#     # PowerShell / Windows
#     iwr -UseBasicParsing -Uri `
#         'https://raw.githubusercontent.com/sharpninja/BitNet-b1.58-Sharp/main/scripts/install-bitnet-worker.ps1' `
#         -OutFile install-bitnet-worker.ps1
#     $env:BITNET_COORDINATOR_URL = 'https://<coordinator>:5001/'
#     $env:BITNET_WORKER_API_KEY  = '<operator-set-key>'
#     pwsh -NoProfile -ExecutionPolicy Bypass -File .\install-bitnet-worker.ps1
#
# Use THIS .env only when you want multiple worker replicas via
# `docker compose up --scale worker=N` on the same host.
# ──────────────────────────────────────────────────────────────────────
# Copy to `.env` next to docker-compose.yml and fill in the values
# before running `docker compose up`. Never commit the real `.env` —
# it contains the shared worker API key.

# ── required ────────────────────────────────────────────────────────────
BITNET_COORDINATOR_URL=https://bitnet-coord.example.com:5001/
BITNET_WORKER_API_KEY=change-me-to-match-Coordinator__WorkerApiKey

# ── optional ────────────────────────────────────────────────────────────
# BITNET_WORKER_ID=worker-a
# BITNET_WORKER_NAME=worker-a
# BITNET_CPU_THREADS=8
# BITNET_HEARTBEAT_SECONDS=30
# BITNET_SHUTDOWN_SECONDS=30
# BITNET_LOG_LEVEL=info
