@page "/admin/install"
@attribute [Authorize(Policy = "AdminPolicy")]
@using BitNetSharp.Distributed.Coordinator.ViewModels
@inject InstallPageViewModel ViewModel

@* Admin-only install page. For every configured worker client,
   shows a copy-pasteable bash script and PowerShell script that
   pins the coordinator URL and the client credentials. The
   operator runs the script on the target machine to bring up a
   worker (Docker-preferred, source-build fallback). Embeds the
   plain-text client secret so access to this page must stay
   behind the AdminPolicy cookie auth wall. *@

<h2>Worker install scripts</h2>
<p>
    Each script pins a single configured worker client's
    credentials and walks through Docker-first / source-build
    fallback install. <strong>Download</strong> the script for the
    target shell via the buttons below (preferred) or copy-paste
    the snippet into a file; run it on the worker machine and the
    worker will calibrate, authenticate against this coordinator,
    and start polling <code>/work</code>.
</p>
<p>
    Per-client one-liners are rendered below. The URLs include the
    current client secret as a <code>?k=</code> query parameter so
    the download endpoint can authenticate the operator without
    needing a browser cookie. Treat them like the scripts themselves
    — rotate via <a href="/admin/api-keys">/admin/api-keys</a> to
    invalidate leaked URLs.
</p>
<p class="warn">
    The scripts include the plain-text client secret — treat them
    like API keys. Rotate via
    <a href="/admin/api-keys">/admin/api-keys</a> if a snippet
    leaks.
</p>

@if (!string.IsNullOrWhiteSpace(ViewModel.LastError))
{
    <p class="warn">@ViewModel.LastError</p>
}

@if (ViewModel.Bundles.Count == 0)
{
    <p class="warn">
        No worker clients configured. Set
        <code>Coordinator__WorkerClients__0__ClientId</code> and
        <code>Coordinator__WorkerClients__0__ClientSecret</code>
        on the coordinator service, then restart.
    </p>
}
else
{
    @foreach (var bundle in ViewModel.Bundles)
    {
        <section style="margin-top:24px; padding-top:16px; border-top:1px solid #333;">
            <h3 style="margin-bottom:4px;">
                <code>@bundle.ClientId</code>
                <span style="color:#999; font-weight:normal;">— @bundle.DisplayName</span>
            </h3>

            @{
                var bashUrl = $"{ViewModel.BaseUrl}/install/{bundle.ClientId}.sh?k={Uri.EscapeDataString(bundle.ClientSecret)}";
                var ps1Url  = $"{ViewModel.BaseUrl}/install/{bundle.ClientId}.ps1?k={Uri.EscapeDataString(bundle.ClientSecret)}";
            }

            <h4 style="margin-top:16px;">
                bash / Linux / macOS
                <a href="@bashUrl"
                   download
                   style="margin-left:12px; font-weight:normal; font-size:0.9em;">[ download .sh ]</a>
            </h4>
            <p style="margin:4px 0 8px 0;"><strong>Remote one-liner:</strong></p>
            <pre style="background:#0c0c0c; padding:12px; overflow-x:auto; border:1px solid #222;"><code>curl -fsSL -o bitnet-worker.sh "@bashUrl" \
  &amp;&amp; chmod +x bitnet-worker.sh &amp;&amp; ./bitnet-worker.sh</code></pre>
            <p style="margin:4px 0 8px 0;"><strong>Rendered script:</strong></p>
            <pre style="background:#0c0c0c; padding:12px; overflow-x:auto; max-height:420px; border:1px solid #222;"><code>@bundle.BashScript</code></pre>

            <h4 style="margin-top:16px;">
                PowerShell / Windows
                <a href="@ps1Url"
                   download
                   style="margin-left:12px; font-weight:normal; font-size:0.9em;">[ download .ps1 ]</a>
            </h4>
            <p style="margin:4px 0 8px 0;"><strong>Remote one-liner:</strong></p>
            <pre style="background:#0c0c0c; padding:12px; overflow-x:auto; border:1px solid #222;"><code>iwr -UseBasicParsing "@ps1Url" -OutFile bitnet-worker.ps1
pwsh -NoProfile -ExecutionPolicy Bypass -File .\bitnet-worker.ps1</code></pre>
            <p style="margin:4px 0 8px 0;"><strong>Rendered script:</strong></p>
            <pre style="background:#0c0c0c; padding:12px; overflow-x:auto; max-height:420px; border:1px solid #222;"><code>@bundle.PowerShellScript</code></pre>
        </section>
    }
}

@code {
    protected override async Task OnInitializedAsync()
    {
        await ViewModel.LoadAsync();
    }
}
