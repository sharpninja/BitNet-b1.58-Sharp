@page "/admin/dashboard"
@attribute [Authorize(Policy = "AdminPolicy")]
@rendermode RenderMode.InteractiveServer
@using BitNetSharp.Distributed.Coordinator.Cqrs.Queries
@using BitNetSharp.Distributed.Coordinator.Persistence
@using BitNetSharp.Distributed.Coordinator.ViewModels
@inject DashboardPageViewModel ViewModel
@inject NavigationManager Navigation
@implements IDisposable

<h2>Fleet dashboard</h2>
<p style="color:#999; font-size:12px;">
    Auto-refresh every 2 s over the InteractiveServer circuit — only
    changed cells repaint. "Live" numbers roll up the last 1 min;
    "Recent" numbers roll up the last 15 min.
</p>

@if (!string.IsNullOrWhiteSpace(ViewModel.LastError))
{
    <p class="warn">@ViewModel.LastError</p>
}

@if (ViewModel.Snapshot is null)
{
    <p>Loading…</p>
}
else
{
    var s = ViewModel.Snapshot;
    @if (s.PruneHealth.ConsecutiveFailures > 0)
    {
        <p class="warn" style="border:1px solid #a33; padding:6px 8px;">
            <strong>Prune service unhealthy:</strong>
            @s.PruneHealth.ConsecutiveFailures consecutive failure(s).
            @if (!string.IsNullOrWhiteSpace(s.PruneHealth.LastFailureMessage))
            {
                <span> Last error: <code>@s.PruneHealth.LastFailureMessage</code></span>
            }
            @if (s.PruneHealth.LastFailureAtUtc is { } at)
            {
                <span style="color:#aaa;"> (@at.ToString("u"))</span>
            }
        </p>
    }
    @if (s.BackupHealth.ConsecutiveFailures > 0)
    {
        <p class="warn" style="border:1px solid #a33; padding:6px 8px;">
            <strong>Backup service unhealthy:</strong>
            @s.BackupHealth.ConsecutiveFailures consecutive failure(s).
            @if (!string.IsNullOrWhiteSpace(s.BackupHealth.LastFailureMessage))
            {
                <span> Last error: <code>@s.BackupHealth.LastFailureMessage</code></span>
            }
            @if (s.BackupHealth.LastFailureAtUtc is { } bat)
            {
                <span style="color:#aaa;"> (@bat.ToString("u"))</span>
            }
        </p>
    }
    else if (s.BackupHealth.LastSuccessAtUtc is { } lastOk)
    {
        <p style="color:#888; font-size:0.9em;">
            Last backup: @lastOk.ToString("u")
            @if (!string.IsNullOrWhiteSpace(s.BackupHealth.LastBackupPath))
            {
                <span> → <code>@s.BackupHealth.LastBackupPath</code></span>
            }
        </p>
    }
    <form method="post" action="/admin/database/vacuum-form" data-enhance="false" style="margin:6px 0;">
        <button type="submit" class="btn" title="PRAGMA wal_checkpoint(TRUNCATE) + VACUUM — reclaims free pages in place. Safe to run anytime; may briefly pause writers.">Vacuum database</button>
    </form>
    var pct = s.Progress.PercentComplete * 100d;
    <section style="margin-top:12px;">
        <div style="display:flex; justify-content:space-between; align-items:baseline;">
            <strong>Overall progress</strong>
            <span style="color:#aaa; font-family:ui-monospace,monospace;">
                @s.Progress.CompletedTasks.ToString("N0") / @s.Progress.TotalTasks.ToString("N0") done
                — @pct.ToString("F1")%
            </span>
        </div>
        <div style="background:#222; border:1px solid #333; height:18px; margin-top:4px; position:relative;">
            <div style="background:#4caf50; height:100%; width:@(pct.ToString("F2"))%;"></div>
        </div>
        <div style="display:flex; gap:16px; flex-wrap:wrap; margin-top:8px; font-size:12px; color:#bbb;">
            <span>Live rate: <strong>@s.Progress.TasksPerSecondLive.ToString("F2")</strong> tasks/s</span>
            <span>Live tokens: <strong>@s.Progress.TokensPerSecondLive.ToString("N0")</strong> tok/s</span>
            <span>Remaining: <strong>@s.Progress.RemainingTasks.ToString("N0")</strong></span>
            <span>ETA:
                @if (s.Progress.EtaSeconds is { } eta)
                {
                    <strong>@FormatDuration(eta)</strong>

                    <text> (</text><time data-utc="@s.Progress.EtaUtc!.Value.ToString("O")">@s.Progress.EtaUtc!.Value.ToString("u")</time><text>)</text>
                }
                else
                {
                    <em style="color:#888;">idle</em>
                }
            </span>
        </div>
    </section>

    <section style="display:flex; gap:16px; flex-wrap:wrap; margin-top:12px;">
        <div class="card">
            <div class="card-label">Weight version</div>
            <div class="card-value">@s.CurrentWeightVersion</div>
            <div class="card-sub">dim @s.WeightDimension</div>
        </div>
        <div class="card">
            <div class="card-label">Pending tasks</div>
            <div class="card-value">@s.Tasks.Pending</div>
        </div>
        <div class="card">
            <div class="card-label">Assigned tasks</div>
            <div class="card-value">@s.Tasks.Assigned</div>
        </div>
        <div class="card" title="Assigned tasks whose lease deadline has passed but whose worker is still sending heartbeats — slow-but-alive, not stuck.">
            <div class="card-label">Soft-expired (alive)</div>
            <div class="card-value @(s.Tasks.SoftExpiredButAlive == 0 ? "" : "warn")">@s.Tasks.SoftExpiredButAlive</div>
        </div>
        <div class="card" title="Assigned tasks whose lease deadline has passed AND whose worker's heartbeat is also stale — genuinely stuck, operator action likely needed.">
            <div class="card-label">Stuck (dead)</div>
            <div class="card-value @(s.Tasks.StuckDead == 0 ? "" : "warn")">@s.Tasks.StuckDead</div>
            @if (s.Tasks.StuckDead > 0)
            {
                <form method="post" action="/admin/tasks/kick-stuck-form" data-enhance="false" style="margin-top:6px;">
                    <button type="submit" class="btn" title="Release stuck-dead Assigned tasks back to Pending">Kick</button>
                </form>
            }
        </div>
        <div class="card">
            <div class="card-label">Done</div>
            <div class="card-value ok">@s.Tasks.Done</div>
        </div>
        <div class="card">
            <div class="card-label">Failed</div>
            <div class="card-value @(s.Tasks.Failed == 0 ? "" : "warn")">@s.Tasks.Failed</div>
        </div>
    </section>

    <h3 style="margin-top:24px;">Workers</h3>
    <section style="display:flex; gap:16px; flex-wrap:wrap;">
        <div class="card">
            <div class="card-label">Configured</div>
            <div class="card-value">@s.Workers.Configured</div>
        </div>
        <div class="card">
            <div class="card-label">Active</div>
            <div class="card-value ok">@s.Workers.Active</div>
        </div>
        <div class="card">
            <div class="card-label">Draining</div>
            <div class="card-value">@s.Workers.Draining</div>
        </div>
        <div class="card">
            <div class="card-label">Gone</div>
            <div class="card-value warn">@s.Workers.Gone</div>
        </div>
    </section>

    <h3 style="margin-top:24px;">Recent activity (last 15 min)</h3>
    <section style="display:flex; gap:16px; flex-wrap:wrap;">
        <div class="card">
            <div class="card-label">Tasks completed</div>
            <div class="card-value">@s.RecentGlobalTelemetry.TasksCompleted</div>
        </div>
        <div class="card">
            <div class="card-label">Tokens processed</div>
            <div class="card-value">@s.RecentGlobalTelemetry.TokensSeen.ToString("N0")</div>
        </div>
        <div class="card">
            <div class="card-label">Fleet wall-clock</div>
            <div class="card-value">@((s.RecentGlobalTelemetry.WallClockMs / 1000.0).ToString("F1")) s</div>
        </div>
        <div class="card">
            <div class="card-label">Avg staleness</div>
            <div class="card-value">@s.RecentGlobalTelemetry.AverageStaleness.ToString("F2")</div>
        </div>
        <div class="card">
            <div class="card-label">Avg loss</div>
            <div class="card-value">@s.RecentGlobalTelemetry.AverageLossAfter.ToString("F3")</div>
        </div>
    </section>

    <h3 style="margin-top:24px;">Registered workers</h3>
    @if (s.WorkerRows.Count == 0)
    {
        <p class="warn">No workers have registered yet.</p>
    }
    else
    {
        <div style="display:flex; gap:12px; align-items:center; margin:8px 0; font-size:12px;">
            <label>Filter by state:
                <select id="worker-filter" onchange="bitnetWorkerGrid.applyFilter(this.value)" style="padding:4px;">
                    <option value="">all</option>
                    <option value="Active" selected>Active</option>
                    <option value="Draining">Draining</option>
                    <option value="Gone">Gone</option>
                </select>
            </label>
            <span style="color:#888;">Click any column header to sort (click again to reverse).</span>
        </div>
        <table id="worker-grid" data-sortable="1">
            <thead>
                <tr>
                    <th data-col="clientId"      data-type="str">Client ID</th>
                    <th data-col="name"          data-type="str">Name</th>
                    <th data-col="state"         data-type="str">State</th>
                    <th data-col="threads"       data-type="num">Threads</th>
                    <th data-col="baselineTps"   data-type="num">Baseline tok/s</th>
                    <th data-col="liveTps"       data-type="num">Live tok/s</th>
                    <th data-col="liveTasks"     data-type="num">Live tasks (1m)</th>
                    <th data-col="currentTask"   data-type="str">Current task</th>
                    <th data-col="onTaskSec"     data-type="num">On task</th>
                    <th data-col="recentTasks"   data-type="num">Recent tasks (15m)</th>
                    <th data-col="avgStaleness"  data-type="num">Avg staleness</th>
                    <th data-col="lastHeartbeat" data-type="num">Last heartbeat</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in s.WorkerRows)
                {
                    <tr data-status="@row.State"
                        data-clientid="@row.ClientId"
                        data-name="@row.Name"
                        data-state="@row.State"
                        data-threads="@row.CpuThreads"
                        data-baselinetps="@row.TokensPerSecond"
                        data-livetps="@row.LiveTokensPerSecond"
                        data-livetasks="@row.LiveTasksCompleted"
                        data-currenttask="@(row.CurrentTaskId ?? string.Empty)"
                        data-ontasksec="@(row.SecondsOnCurrentTask ?? 0d)"
                        data-recenttasks="@row.RecentTasksCompleted"
                        data-avgstaleness="@row.RecentAverageStaleness"
                        data-lastheartbeat="@row.LastHeartbeatUtc.ToUnixTimeSeconds()">
                        <td>@row.ClientId</td>
                        <td>@row.Name</td>
                        <td class="@(row.State == WorkerState.Active ? "ok" : row.State == WorkerState.Gone ? "warn" : "")">@row.State</td>
                        <td>@row.CpuThreads</td>
                        <td>@row.TokensPerSecond.ToString("N0")</td>
                        <td><strong>@row.LiveTokensPerSecond.ToString("N0")</strong></td>
                        <td>@row.LiveTasksCompleted</td>
                        <td>
                            @if (row.CurrentTaskId is { } cur)
                            {
                                <span style="font-family:ui-monospace,monospace; font-size:11px;">@cur.Substring(0, Math.Min(8, cur.Length))…</span>
                            }
                            else
                            {
                                <em style="color:#888;">idle</em>
                            }
                        </td>
                        <td>@(row.SecondsOnCurrentTask is { } secs ? FormatDuration(secs) : "—")</td>
                        <td>@row.RecentTasksCompleted</td>
                        <td>@row.RecentAverageStaleness.ToString("F2")</td>
                        <td><time data-utc="@row.LastHeartbeatUtc.ToString("O")">@row.LastHeartbeatUtc.ToString("u")</time></td>
                        <td style="display:flex; gap:6px;">
                            <form method="post" action="@($"/admin/workers/{row.ClientId}/drain?redirect=/admin/dashboard")" style="margin:0;">
                                <button class="btn" type="submit">Drain</button>
                            </form>
                            <form method="post" action="@($"/admin/workers/{row.ClientId}/gone?redirect=/admin/dashboard")" style="margin:0;">
                                <button class="btn" type="submit">Gone</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <p style="color:#666; font-size:11px; margin-top:12px;">
        Snapshot generated <time data-utc="@s.GeneratedAtUtc.ToString("O")">@s.GeneratedAtUtc.ToString("u")</time>.
    </p>

    <style>
        .card { background:#1c1c1c; border:1px solid #333; padding:12px 16px; min-width:150px; }
        .card-label { font-size:11px; color:#888; text-transform:uppercase; letter-spacing:0.05em; }
        .card-value { font-size:24px; font-family:ui-monospace,monospace; margin-top:4px; }
        .card-sub { font-size:11px; color:#666; }
    </style>
}

@code {
    private System.Threading.Timer? _refreshTimer;

    protected override async Task OnInitializedAsync()
    {
        await ViewModel.LoadAsync();

        // Auto-refresh via a background timer every 2 seconds. The
        // InvokeAsync + StateHasChanged combo pushes the diff over
        // the InteractiveServer circuit so only changed DOM elements
        // repaint.
        _refreshTimer = new System.Threading.Timer(async _ =>
        {
            try
            {
                await InvokeAsync(async () =>
                {
                    await ViewModel.LoadAsync();
                    StateHasChanged();
                });
            }
            catch
            {
                // Timer callback errors must not crash the circuit.
            }
        }, null, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(2));
    }

    public void Dispose()
    {
        _refreshTimer?.Dispose();
    }

    private static string FormatDuration(double seconds)
    {
        if (double.IsNaN(seconds) || double.IsInfinity(seconds) || seconds < 0d)
        {
            return "—";
        }
        var span = TimeSpan.FromSeconds(seconds);
        if (span.TotalHours >= 1d)
        {
            return $"{(int)span.TotalHours}h {span.Minutes}m";
        }
        if (span.TotalMinutes >= 1d)
        {
            return $"{(int)span.TotalMinutes}m {span.Seconds}s";
        }
        return $"{span.TotalSeconds:F1}s";
    }
}
