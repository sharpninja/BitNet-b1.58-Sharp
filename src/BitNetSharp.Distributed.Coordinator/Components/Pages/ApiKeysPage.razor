@page "/admin/api-keys"
@attribute [Authorize(Policy = "AdminPolicy")]
@using BitNetSharp.Distributed.Coordinator.ViewModels
@inject ApiKeysPageViewModel ViewModel

@* Admin-only page that lists every configured worker OAuth client
   with its client_id, display name, plain-text client_secret, and
   a rotate button. Code-behind is a single OnInitializedAsync
   forwarding to the ViewModel — no business logic here. *@

<h2>Worker API keys</h2>
<p>
    Copy the client secret into the corresponding worker's
    <code>BITNET_CLIENT_SECRET</code> environment variable. Rotating
    a key immediately invalidates any JWT previously issued for that
    client; the worker must be restarted with the new secret to
    re-authenticate.
</p>

@if (!string.IsNullOrWhiteSpace(ViewModel.RotatedClientId))
{
    <p class="warn">
        Rotated <code>@ViewModel.RotatedClientId</code>. The new secret
        is shown in the table below. Old JWTs for this client will be
        rejected immediately.
    </p>
}

@if (!string.IsNullOrWhiteSpace(ViewModel.LastError))
{
    <p class="warn">@ViewModel.LastError</p>
}

@if (ViewModel.Clients.Count == 0)
{
    <p class="warn">
        No worker clients configured. Set
        <code>Coordinator__WorkerClients__0__ClientId</code> and
        <code>Coordinator__WorkerClients__0__ClientSecret</code>
        (plus any additional numbered entries) in the coordinator's
        environment, then restart.
    </p>
}
else
{
    <table>
        <thead>
            <tr>
                <th>Client ID</th>
                <th>Display name</th>
                <th>Client secret (API key)</th>
                <th>Revoked at (UTC)</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var entry in ViewModel.Clients)
            {
                <tr>
                    <td>@entry.ClientId</td>
                    <td>@entry.DisplayName</td>
                    <td class="secret">@entry.ClientSecret</td>
                    <td class="@(entry.RevokedAtUtc is null ? "" : "revoked")">
                        @(entry.RevokedAtUtc?.ToString("u") ?? "—")
                    </td>
                    <td>
                        <form method="post" action="@($"/admin/rotate/{entry.ClientId}?redirect=/admin/api-keys")">
                            <button class="btn" type="submit">Rotate</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    [SupplyParameterFromQuery(Name = "rotated")]
    public string? RotatedClientId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        ViewModel.RotatedClientId = RotatedClientId;
        await ViewModel.LoadAsync();
    }
}
